# ──────────────────────────────────────────────────────────────────────────────
# NexusAI-BankGuard — Environment Variables Template
# ──────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# On Vercel: set these under Project → Settings → Environment Variables
# ──────────────────────────────────────────────────────────────────────────────

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Replace with your Atlas connection string.
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGO_URI=your_atlas_connection_string_here

# ── Database name (default: BankGuard) ───────────────────────────────────────
MONGO_DB_NAME=BankGuard

# ── Google Gemini AI ──────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── Agent mode ────────────────────────────────────────────────────────────────
# Set to "true" to skip real Gemini AI calls and use deterministic mock responses.
MOCK_AGENTS=false

# ── Local development ─────────────────────────────────────────────────────────
PORT=8000
